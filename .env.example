# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Site ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://runitsimply.com

# ─── Admin ───────────────────────────────────────────────────────────────────
# Comma-separated admin emails (used in middleware and sidebar)
NEXT_PUBLIC_ADMIN_EMAILS=
ADMIN_EMAILS=
# Secret for admin API routes (/api/admin/*)
ADMIN_SECRET_KEY=

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=
# Where contact form submissions are delivered
CONTACT_FORM_EMAIL=

# ─── Stripe (Subscription Billing) ───────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# ─── Twilio (SMS) ────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Manual payment info (shown to subscribers for manual payment) ────────────
PLATFORM_VENMO_HANDLE=
PLATFORM_ZELLE_EMAIL=
